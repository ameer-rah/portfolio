@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

:root {
  --pixel-green:  #00cc66;
  --pixel-dark:   #000000;
  --pixel-darker: #000000;
  --pixel-amber:  #ffb700;   
  --pixel-cyan:   #00cc66;   
  --pixel-red:    #ff3333;
  --pixel-purple: #cc44ff;
  --pixel-white:  #cccccc;
  --pixel-gray:   #3a3a3a;
  --pixel-mid:    #0d0d0d;
  --font-pixel:   "Press Start 2P", monospace;
  --border-pixel: 2px solid var(--pixel-green);
}

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  image-rendering: pixelated;
}

html, body, #root {
  height: 100%;
  width: 100%;
  background: var(--pixel-darker);
  color: var(--pixel-green);
  font-family: var(--font-pixel);
  font-size: 10px;
  line-height: 1.8;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }
button { cursor: pointer; background: none; border: none; font-family: inherit; }
ul { list-style: none; }

.game-shell {
  height: 100vh;
  width: 100vw;
  display: flex;
  flex-direction: column;
  background: var(--pixel-dark);
  position: relative;
  overflow: hidden;
}

.game-shell::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.07) 2px,
    rgba(0,0,0,0.07) 4px
  );
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  border-bottom: 1px solid var(--pixel-green);
  background: #000;
  flex-shrink: 0;
  gap: 12px;
  overflow: hidden;
}

.top-bar-left {
  display: flex;
  align-items: center;
  gap: 12px;
  overflow: hidden;
  min-width: 0;
}

.top-bar-binary {
  font-size: 6px;
  color: #1a4d2e;
  letter-spacing: 2px;
  white-space: nowrap;
  overflow: hidden;
  flex-shrink: 1;
  min-width: 0;
}

.top-bar-title {
  font-size: 9px;
  color: var(--pixel-green);
  letter-spacing: 4px;
  white-space: nowrap;
  flex-shrink: 0;
  text-shadow: 0 0 10px var(--pixel-green);
}

.top-bar-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.hp-label {
  font-size: 7px;
  color: var(--pixel-red);
}

.hp-hearts {
  display: flex;
  gap: 3px;
}

.hp-block {
  width: 10px;
  height: 10px;
  background: var(--pixel-red);
  border: 1px solid #ff6666;
  animation: hpPulse 1.5s ease-in-out infinite;
}

.hp-block:nth-child(2) { animation-delay: 0.15s; }
.hp-block:nth-child(3) { animation-delay: 0.30s; }
.hp-block:nth-child(4) { animation-delay: 0.45s; }
.hp-block:nth-child(5) { animation-delay: 0.60s; }

.level-badge {
  font-size: 7px;
  color: var(--pixel-amber);
  border: 1px solid var(--pixel-amber);
  padding: 2px 6px;
}

.nav-menu {
  display: flex;
  width: 100%;
  border-bottom: 1px solid var(--pixel-green);
  background: #000;
  flex-shrink: 0;
}

.nav-btn {
  flex: 1;
  padding: 8px 4px;
  font-size: 7px;
  color: #888888;
  border: none;
  transition: color 0.1s;
  letter-spacing: 1px;
  white-space: nowrap;
  text-align: center;
}

.nav-btn:hover {
  color: #bbbbbb;
}

.nav-btn-active {
  color: #ffffff !important;
  text-shadow: none;
}

.game-content {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
  animation: screenIn 0.18s ease-out;
}

/* Dungeons fills 100% — no padding, flex column so dg-wrap can stretch */
.game-content--full {
  padding: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.game-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  border-top: 2px solid var(--pixel-green);
  background: var(--pixel-darker);
  flex-shrink: 0;
  flex-wrap: wrap;
  gap: 8px;
}

.exp-section {
  display: flex;
  align-items: center;
  gap: 8px;
}

.exp-label { font-size: 7px; color: var(--pixel-purple); }
.exp-value { font-size: 7px; color: var(--pixel-purple); }

.exp-bar-track {
  width: 100px;
  height: 8px;
  background: var(--pixel-gray);
  border: 1px solid #555;
}

.exp-bar-fill {
  height: 100%;
  width: 78%;
  background: var(--pixel-purple);
  animation: glow 2s ease-in-out infinite;
}

.controls-hint {
  display: flex;
  gap: 16px;
  font-size: 6px;
  color: var(--pixel-gray);
}

.pixel-box {
  border: 2px solid var(--pixel-green);
  box-shadow: 0 0 0 1px #000;
  background: var(--pixel-mid);
}

.pixel-box-amber {
  border: 2px solid var(--pixel-amber);
  box-shadow: 0 0 0 1px #000;
  background: var(--pixel-mid);
}

.screen-header {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--pixel-green);
}

.screen-title {
  font-size: 10px;
  color: var(--pixel-green);
  text-shadow: 0 0 10px var(--pixel-green);
}

.screen-subtitle {
  font-size: 7px;
  color: var(--pixel-gray);
}

.home-screen {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.home-top {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.character-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  min-width: 120px;
}

.pixel-sprite-wrap {
  padding: 12px;
  border: 2px solid var(--pixel-green);
  background: var(--pixel-mid);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pixel-sprite {
  animation: bounce 0.8s ease-in-out infinite alternate;
}

.char-name-plate {
  text-align: center;
}

.char-name {
  font-size: 9px;
  color: var(--pixel-white);
}

.char-class {
  font-size: 6px;
  color: var(--pixel-amber);
  margin-top: 4px;
}

.dialog-panel {
  flex: 1;
  min-width: 200px;
  padding: 12px;
}

.dialog-header {
  font-size: 7px;
  color: var(--pixel-green);
  margin-bottom: 10px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--pixel-green);
}

.dialog-body {
  min-height: 80px;
}

.dialog-line {
  font-size: 7px;
  color: var(--pixel-white);
  line-height: 2;
  white-space: pre;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.stat-card {
  padding: 10px;
}

.stat-label {
  font-size: 6px;
  color: var(--pixel-gray);
  margin-bottom: 6px;
  letter-spacing: 1px;
}

.stat-bar {
  height: 8px;
  background: var(--pixel-gray);
  border: 1px solid #555;
  margin-bottom: 4px;
}

.stat-fill {
  height: 100%;
  transition: width 1.2s ease;
  animation: glow 2s ease-in-out infinite;
}

.stat-value {
  font-size: 7px;
}

.docs-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.doc-card {
  flex: 1;
  min-width: 180px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  transition: border-color 0.1s, box-shadow 0.1s;
  text-decoration: none;
}

.doc-card:hover {
  border-color: var(--pixel-amber);
  box-shadow: 0 0 8px rgba(255,183,0,0.2);
}

.doc-icon {
  font-size: 18px;
  image-rendering: auto;
  flex-shrink: 0;
}

.doc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.doc-name {
  font-size: 8px;
  color: var(--pixel-amber);
}

.doc-sub {
  font-size: 6px;
  color: var(--pixel-gray);
}

.doc-action {
  font-size: 6px;
  color: var(--pixel-green);
  flex-shrink: 0;
}

.doc-card:hover .doc-action {
  color: var(--pixel-amber);
}

.home-bio {
  padding: 10px 12px;
  font-size: 7px;
  line-height: 2;
}

/* ─── HOME SECTIONS ──────────────────────────────────────────── */
.home-section-header {
  margin-top: 4px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--pixel-green);
}

.home-section-title {
  font-size: 8px;
  color: var(--pixel-green);
  letter-spacing: 2px;
}

/* ─── EDUCATION ──────────────────────────────────────────────── */
.edu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.edu-card {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.edu-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.edu-abbr {
  font-size: 10px;
  color: var(--pixel-amber);
}

.edu-gpa {
  font-size: 7px;
  color: var(--pixel-green);
  border: 1px solid var(--pixel-green);
  padding: 2px 6px;
}

.edu-name {
  font-size: 7px;
  color: var(--pixel-white);
  line-height: 1.8;
}

.edu-degree {
  font-size: 6px;
  color: var(--pixel-cyan);
}

.edu-minor {
  font-size: 6px;
  color: var(--pixel-gray);
}

.edu-period {
  font-size: 6px;
  color: var(--pixel-gray);
  margin-top: 2px;
}

.edu-honors {
  font-size: 6px;
  color: var(--pixel-amber);
  margin-top: 2px;
}

.edu-courses {
  font-size: 6px;
  color: var(--pixel-gray);
  line-height: 1.8;
  margin-top: 4px;
  border-top: 1px solid var(--pixel-gray);
  padding-top: 6px;
}

.edu-courses-label {
  color: var(--pixel-green);
}

/* ─── LORE / WHAT DRIVES ME ──────────────────────────────────── */
.lore-box {
  padding: 14px;
}

.lore-quote {
  font-size: 8px;
  color: var(--pixel-white);
  line-height: 2;
  font-style: italic;
}

.lore-cite {
  font-size: 6px;
  color: var(--pixel-amber);
  margin-top: 4px;
  margin-bottom: 12px;
}

.lore-paragraphs {
  display: flex;
  flex-direction: column;
  gap: 10px;
  border-top: 1px solid var(--pixel-gray);
  padding-top: 12px;
}

.lore-p {
  font-size: 7px;
  color: var(--pixel-gray);
  line-height: 2;
}

.bio-label {
  color: var(--pixel-amber);
}

.bio-text {
  color: var(--pixel-white);
}

/* ─── QUEST LOG ──────────────────────────────────────────────── */
.quest-log {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* ── Quest map: interactive path layout ── */
.quest-map {
  position: relative;
}

.quest-path-row {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 0 10px;
}

/* Node column (left side: path line + dot) */
.quest-node-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.quest-node-col:hover .qnode {
  filter: brightness(1.5);
  transform: scale(1.2);
}

/* Path lines connecting dots */
.qline {
  flex: 1;
  width: 2px;
  min-height: 10px;
  background: var(--pixel-gray);
  transition: background 0.35s ease, box-shadow 0.35s ease;
}

.qline.lit {
  background: var(--pixel-green);
  box-shadow: 0 0 6px var(--pixel-green);
}

/* Waypoint dot */
.qnode {
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 8px;
  border: 2px solid;
  background: var(--pixel-mid);
  flex-shrink: 0;
  z-index: 2;
  transition: transform 0.15s, filter 0.15s, border-color 0.2s, box-shadow 0.2s;
}

.qnode.active {
  color: var(--pixel-green);
  border-color: var(--pixel-green);
  animation: badgePulse 1.2s ease-in-out infinite;
}

.qnode.complete {
  color: var(--pixel-gray);
  border-color: var(--pixel-gray);
}

.qnode.here {
  color: var(--pixel-amber) !important;
  border-color: var(--pixel-amber) !important;
  box-shadow: 0 0 10px rgba(255, 183, 0, 0.5);
  animation: none !important;
  transform: scale(1.15);
}

/* Card column (right side) */
.quest-card-col {
  padding: 6px 0;
}

/* Quest card */
.quest-card {
  padding: 12px;
  cursor: pointer;
  transition: border-color 0.15s, background 0.1s, box-shadow 0.2s;
}

.quest-card:hover {
  background: #1a1a1a;
}

.quest-card.active {
  border-color: var(--pixel-green);
}

.quest-card.complete {
  border-color: var(--pixel-gray);
  opacity: 0.85;
}

/* Sprite is currently at this quest */
.quest-card.here {
  border-color: var(--pixel-amber) !important;
  box-shadow: 0 0 14px rgba(255, 183, 0, 0.15);
  opacity: 1 !important;
}

/* Sprite pin: absolutely positioned, travels along the path */
.qsprite-pin {
  position: absolute;
  left: 0;
  width: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translateY(-50%);
  z-index: 10;
  pointer-events: none;
}

/* Thought bubble */
.quest-bubble {
  position: absolute;
  left: 44px;
  top: 50%;
  transform: translateY(-60%);
  font-size: 5px;
  color: #000;
  border: 1px solid #fff;
  border-radius: 6px;
  padding: 4px 7px;
  background: #fff;
  white-space: nowrap;
  z-index: 11;
  animation: screenIn 0.15s ease-out;
}

/* Thought dots: three descending circles toward the sprite */
.quest-bubble::before {
  content: '· ·';
  position: absolute;
  right: calc(100% + 2px);
  bottom: 2px;
  font-size: 7px;
  color: #fff;
  letter-spacing: 2px;
  line-height: 1;
}

.quest-bubble::after {
  content: '·';
  position: absolute;
  right: calc(100% - 4px);
  bottom: -6px;
  font-size: 9px;
  color: #fff;
  line-height: 1;
}

/* Sprite animations */
.quest-sprite-idle {
  animation: bounce 0.8s ease-in-out infinite alternate;
  filter: drop-shadow(0 0 4px #00cc66);
}

.quest-sprite-walk {
  animation: questWalk 0.22s ease-in-out infinite alternate;
  filter: drop-shadow(0 0 6px var(--pixel-amber));
}

/* Bottom hint */
.quest-travel-hint {
  font-size: 6px;
  color: var(--pixel-gray);
  text-align: center;
  letter-spacing: 1px;
  animation: badgePulse 2s ease-in-out infinite;
}

.quest-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 8px;
}

.quest-header-left {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.quest-name {
  font-size: 8px;
  color: var(--pixel-amber);
}

.quest-role {
  font-size: 7px;
  color: var(--pixel-green);
}

.quest-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
}

.badge {
  font-size: 6px;
  padding: 2px 6px;
  border: 1px solid;
}

.badge-active {
  color: var(--pixel-green);
  border-color: var(--pixel-green);
  animation: badgePulse 1.2s ease-in-out infinite;
}

.badge-complete {
  color: var(--pixel-gray);
  border-color: var(--pixel-gray);
}

.quest-period {
  font-size: 6px;
  color: var(--pixel-gray);
}

.quest-body {
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px solid var(--pixel-gray);
}

.quest-bullets {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.quest-bullets li {
  font-size: 7px;
  color: var(--pixel-white);
  line-height: 1.8;
}

.quest-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 10px;
}

.quest-tag {
  font-size: 6px;
  color: var(--pixel-cyan);
  border: 1px solid var(--pixel-cyan);
  padding: 2px 6px;
}

.quest-expand-hint {
  margin-top: 8px;
  font-size: 6px;
  color: var(--pixel-gray);
  text-align: right;
}

/* ─── INVENTORY ──────────────────────────────────────────────── */
.inv-shell {
  display: grid;
  grid-template-columns: 220px 1fr;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

/* Left panel */
.inv-left {
  display: flex;
  flex-direction: column;
  border-right: 2px solid #1a2a1a;
  background: #000;
  overflow-y: auto;
  overflow-x: hidden;
}

.inv-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  border-bottom: 1px solid #1a2a1a;
  flex-shrink: 0;
}
.inv-panel-title { font-size: 7px; color: var(--pixel-green); letter-spacing: 2px; }
.inv-slot-count  { font-size: 6px; color: var(--pixel-gray); }

/* Character card */
.inv-char-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 10px 10px;
  border-bottom: 1px solid #1a2a1a;
  flex-shrink: 0;
}

.inv-sprite-wrap {
  width: 110px;
  height: 110px;
  background: #0a140a;
  border: 2px solid #1a3a1a;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.inv-sprite {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
}

.px-head {
  width: 18px;
  height: 18px;
  background: #c8a87a;
  border: 2px solid #6b5040;
  position: relative;
}
.px-head::before {
  content: '';
  position: absolute;
  top: 4px; left: 3px;
  width: 4px; height: 4px;
  background: #1a1a2e;
  box-shadow: 6px 0 0 #1a1a2e;
}

.px-body {
  width: 22px;
  height: 20px;
  background: #3355aa;
  border: 2px solid #1a3377;
  position: relative;
}
.px-body::after {
  content: '';
  position: absolute;
  top: 4px; left: 50%;
  transform: translateX(-50%);
  width: 8px; height: 8px;
  background: #5577cc;
  border: 1px solid #3355aa;
}

.px-legs {
  width: 20px;
  height: 12px;
  background: #1a1a2e;
  border: 2px solid #334;
  position: relative;
}
.px-legs::after {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 2px; height: 100%;
  background: #000;
}

.inv-char-name  { font-size: 6px; color: var(--pixel-white); margin-bottom: 2px; text-align: center; }
.inv-char-class { font-size: 5px; color: var(--pixel-amber); letter-spacing: 1px; text-align: center; }

/* Section label */
.inv-section-label {
  font-size: 5px;
  color: var(--pixel-gray);
  letter-spacing: 2px;
  padding: 6px 10px 4px;
  flex-shrink: 0;
}

/* Equip slots */
.inv-equip-slots {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 0 8px 8px;
  flex-shrink: 0;
}

.inv-equip-row {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 6px;
  border: 1px solid #1a2a1a;
  background: #050c05;
}

.inv-equip-row--filled {
  border-color: #1a3a1a;
  background: #080f08;
}

.inv-equip-icon {
  width: 22px;
  height: 22px;
  border: 1px solid #1a3a1a;
  background: #0a140a;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.inv-equip-placeholder { font-size: 8px; color: #1a3a1a; }

.inv-equip-info { flex: 1; min-width: 0; }
.inv-equip-slot-label { font-size: 5px; color: var(--pixel-gray); margin-bottom: 1px; }
.inv-equip-item-name  { font-size: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.inv-equip-empty      { font-size: 5px; color: #1a3a1a; }

.inv-unequip-btn {
  font-family: var(--font-pixel);
  font-size: 7px;
  color: #553333;
  padding: 2px 4px;
  background: none;
  border: 1px solid #331a1a;
  cursor: pointer;
  flex-shrink: 0;
  transition: color 0.1s, border-color 0.1s;
}
.inv-unequip-btn:hover { color: var(--pixel-red); border-color: var(--pixel-red); }

/* Stats bars */
.inv-stats {
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 0 8px 10px;
  flex-shrink: 0;
}

.inv-stat-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.inv-stat-label {
  font-size: 5px;
  color: var(--pixel-gray);
  width: 22px;
  flex-shrink: 0;
}

.inv-stat-track {
  flex: 1;
  height: 6px;
  background: #0a140a;
  border: 1px solid #1a2a1a;
  overflow: hidden;
}

.inv-stat-fill {
  height: 100%;
  background: var(--pixel-green);
  transition: width 0.3s ease;
  min-width: 0;
}

.inv-stat-val {
  font-size: 5px;
  color: var(--pixel-green);
  width: 20px;
  text-align: right;
  flex-shrink: 0;
}

/* Right panel */
.inv-right {
  display: flex;
  flex-direction: column;
  background: #050c05;
  overflow: hidden;
}

/* Tabs */
.inv-tabs {
  display: flex;
  border-bottom: 2px solid #1a2a1a;
  flex-shrink: 0;
}

.inv-tab {
  font-family: var(--font-pixel);
  font-size: 7px;
  padding: 8px 14px;
  background: transparent;
  border: none;
  border-right: 1px solid #1a2a1a;
  color: var(--pixel-gray);
  cursor: pointer;
  transition: color 0.1s, background 0.1s;
  letter-spacing: 1px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  align-items: flex-start;
}
.inv-tab:hover    { color: var(--pixel-white); background: #0a140a; }
.inv-tab--active  { color: var(--pixel-green); background: #0a180a; border-bottom: 2px solid var(--pixel-green); margin-bottom: -2px; }

.inv-tab-label { font-size: 7px; }
.inv-tab-sub   { font-size: 5px; color: var(--pixel-gray); letter-spacing: 1px; }
.inv-tab--active .inv-tab-sub { color: #336633; }

/* Item list */
.inv-item-list {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.inv-item-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-bottom: 1px solid #0d1a0d;
  cursor: pointer;
  transition: background 0.08s;
}
.inv-item-row:hover        { background: #0a140a; }
.inv-item-row--selected    { background: #0d1a0d; border: 1px solid #1a3a1a; }
.inv-item-row--equipped    { opacity: 0.65; }

.inv-item-icon {
  width: 36px;
  height: 36px;
  border: 2px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.inv-item-info { flex: 1; min-width: 0; }

.inv-item-name-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 3px;
  flex-wrap: wrap;
}

.inv-item-name {
  font-size: 8px;
}

.inv-rarity-badge {
  font-size: 5px;
  padding: 2px 5px;
  border: 1px solid;
  letter-spacing: 1px;
}

.inv-equipped-badge {
  font-size: 5px;
  padding: 2px 5px;
  border: 1px solid var(--pixel-green);
  color: var(--pixel-green);
  letter-spacing: 1px;
}

.inv-item-stats {
  font-size: 5px;
  color: var(--pixel-gray);
  margin-bottom: 3px;
}

.inv-item-stars {
  font-size: 8px;
}

.inv-equip-btn {
  font-family: var(--font-pixel);
  font-size: 6px;
  padding: 6px 10px;
  background: transparent;
  border: 2px solid var(--pixel-green);
  color: var(--pixel-green);
  cursor: pointer;
  transition: background 0.08s;
  flex-shrink: 0;
  white-space: nowrap;
}
.inv-equip-btn:hover:not(:disabled) { background: rgba(0,204,102,0.12); }
.inv-equip-btn:disabled { border-color: #1a3a1a; color: #1a3a1a; cursor: not-allowed; }

.inv-cert-badge {
  font-family: var(--font-pixel);
  font-size: 6px;
  padding: 6px 10px;
  border: 2px solid;
  flex-shrink: 0;
  white-space: nowrap;
  letter-spacing: 1px;
}

/* Detail bar */
.inv-detail-bar {
  border-top: 2px solid #1a2a1a;
  padding: 10px 14px;
  min-height: 44px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.inv-detail-text {
  font-size: 6px;
  color: var(--pixel-white);
  line-height: 2;
}

.inv-detail-placeholder {
  font-size: 6px;
  color: var(--pixel-gray);
  letter-spacing: 1px;
}

/* Scrollbar */
.inv-item-list::-webkit-scrollbar,
.inv-left::-webkit-scrollbar { width: 4px; }
.inv-item-list::-webkit-scrollbar-track,
.inv-left::-webkit-scrollbar-track { background: #000; }
.inv-item-list::-webkit-scrollbar-thumb,
.inv-left::-webkit-scrollbar-thumb { background: #1a3a1a; }

/* ─── DUNGEONS ───────────────────────────────────────────────── */
@keyframes torchFlicker {
  0%, 100% { opacity: 1;   filter: drop-shadow(0 0 5px #ff8800); }
  20%       { opacity: 0.8; filter: drop-shadow(0 0 2px #ffb700); }
  50%       { opacity: 1;   filter: drop-shadow(0 0 8px #ff4400); }
  75%       { opacity: 0.9; filter: drop-shadow(0 0 3px #ff8800); }
}
@keyframes bossGlow {
  0%, 100% { box-shadow: 0 0 6px  var(--boss-accent, var(--pixel-green)),
                         inset 0 0 20px rgba(0,0,0,0.6); }
  50%       { box-shadow: 0 0 18px var(--boss-accent, var(--pixel-green)),
                         inset 0 0 20px rgba(0,0,0,0.3); }
}
@keyframes hpDrain {
  from { width: 0%; }
}
@keyframes vaultPulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.6; }
}

.dungeons {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ── Torch ── */
.dungeon-torch {
  display: inline-block;
  font-size: 16px;
  animation: torchFlicker 0.7s ease-in-out infinite;
}

/* ── Header row ── */
.dungeon-header {
  display: flex;
  align-items: center;
  gap: 10px;
}
.dungeon-header .screen-header {
  flex: 1;
}

/* ── Floor overview row (map + info) ── */
.dungeon-floor-header {
  display: flex;
  gap: 10px;
  align-items: stretch;
}

/* ── Mini SVG map ── */
.dungeon-map {
  padding: 10px 12px;
  flex: 1;
}
.dungeon-map-label {
  font-size: 6px;
  color: var(--pixel-gray);
  letter-spacing: 2px;
  margin-bottom: 8px;
}
.dmap-svg { display: block; width: 100%; height: auto; }

/* ── Floor info panel ── */
.dungeon-floor-info {
  padding: 10px 14px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  min-width: 130px;
}
.dungeon-floor-title {
  font-size: 8px;
  color: var(--pixel-green);
  margin-bottom: 4px;
}
.dungeon-floor-stat {
  font-size: 6px;
  color: var(--pixel-gray);
  line-height: 1.8;
}

/* ── Section labels ── */
.dungeon-section-label {
  font-size: 7px;
  color: var(--pixel-gray);
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.dungeon-repo-count { color: var(--pixel-cyan); }

/* ── Boss grid ── */
.dungeon-boss-grid {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* Boss room card */
.boss-room {
  border: 2px solid var(--boss-accent, var(--pixel-green));
  background: var(--pixel-dark);
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.boss-room--active {
  animation: bossGlow 1.8s ease-in-out infinite;
}

.boss-room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5px 12px;
  border-bottom: 1px solid var(--boss-accent, var(--pixel-green));
  background: rgba(0,0,0,0.4);
}
.boss-room-floor {
  font-size: 6px;
  letter-spacing: 2px;
}
.boss-room-type {
  font-size: 5px;
  color: var(--pixel-gray);
  letter-spacing: 1px;
}

.boss-room-body {
  display: flex;
  gap: 14px;
  padding: 12px 14px;
  align-items: flex-start;
}

/* Large monster glyph */
.boss-monster-art {
  font-size: 34px;
  line-height: 1;
  min-width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: glow 2s ease-in-out infinite;
  filter: drop-shadow(0 0 8px currentColor);
  flex-shrink: 0;
  padding-top: 4px;
}
.boss-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

/* HP difficulty bar */
.dungeon-diff-bar-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.dungeon-diff-icon  { font-size: 10px; }
.dungeon-diff-label { font-size: 6px; min-width: 76px; }
.dungeon-hp-track {
  flex: 1;
  height: 6px;
  background: #111;
  border: 1px solid var(--pixel-gray);
  overflow: hidden;
  min-width: 40px;
}
.dungeon-hp-fill {
  height: 100%;
  animation: hpDrain 1.2s ease-out;
}
.dungeon-hp-val {
  font-size: 5px;
  min-width: 38px;
  text-align: right;
}

/* Boss action bar */
.boss-room-actions {
  display: flex;
  gap: 12px;
  padding: 7px 14px;
  border-top: 1px solid #1a1a1a;
  background: rgba(0,0,0,0.25);
  flex-wrap: wrap;
}
.boss-raid-btn {
  font-size: 7px;
  font-family: var(--font-pixel);
  border: 1px solid;
  padding: 4px 12px;
  letter-spacing: 1px;
  transition: filter 0.1s, background 0.1s;
  cursor: pointer;
}
.boss-raid-btn:hover {
  filter: brightness(1.35);
  background: rgba(255,255,255,0.04);
}

/* ── Dungeon shared atoms ── */
.dungeon-name  { font-size: 9px; margin-bottom: 2px; }
.dungeon-type  { font-size: 6px; color: var(--pixel-gray); }
.dungeon-desc  { font-size: 7px; color: var(--pixel-white); line-height: 2; }
.dungeon-stack { display: flex; flex-wrap: wrap; gap: 6px; }
.dungeon-tag   { font-size: 6px; padding: 2px 6px; border: 1px solid var(--pixel-gray); color: var(--pixel-gray); }
.dungeon-links { display: flex; gap: 12px; align-items: center; }
.dungeon-link  { font-size: 7px; color: var(--pixel-green); transition: color 0.1s; }
.dungeon-link:hover { color: var(--pixel-amber); }
.dungeon-stars { font-size: 7px; color: var(--pixel-amber); margin-left: auto; }

/* ── Treasure vaults ── */
.dungeon-vault-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
.treasure-vault {
  border: 2px solid var(--vault-accent, var(--pixel-gray));
  background: var(--pixel-dark);
  padding: 10px;
  display: flex;
  gap: 10px;
  align-items: flex-start;
  transition: border-color 0.15s;
}
.treasure-vault:hover {
  border-color: var(--pixel-amber);
}
.vault-chest-icon {
  font-size: 22px;
  line-height: 1;
  padding-top: 2px;
  flex-shrink: 0;
  animation: vaultPulse 2s ease-in-out infinite;
}
.vault-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }

/* ── Loading / error ── */
.dungeon-loading {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px;
  font-size: 7px;
  color: var(--pixel-gray);
}
.dungeon-loading-text { animation: badgePulse 1s ease-in-out infinite; }
.dungeon-error {
  padding: 10px 12px;
  font-size: 7px;
  color: var(--pixel-amber);
}

/* ─── LIBRARY / BOOKSHELF ────────────────────────────────────── */
.library {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.lib-loading {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px;
  font-size: 7px;
  color: var(--pixel-gray);
}

/* ── Shelf structure ── */
.bookshelf {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.shelf-books {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  padding: 0 12px;
  flex-wrap: nowrap;
  min-height: 140px;
  overflow: visible;
}

/* Individual book spine */
.book-spine {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid;
  border-bottom: none;
  position: relative;
  transition: transform 0.1s, box-shadow 0.1s;
  overflow: hidden;
}

.book-spine:hover {
  transform: translateY(-4px);
}

.book-spine-selected {
  transform: translateY(-8px) !important;
}

.book-spine-label {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
  font-size: 5px;
  font-family: var(--font-pixel);
  letter-spacing: 1px;
  padding: 6px 2px;
  line-height: 1.4;
  text-align: center;
  overflow: hidden;
  max-height: 90%;
  word-break: break-word;
}

.book-spine-type {
  font-size: 6px;
  margin-top: auto;
  padding-bottom: 4px;
}

/* Shelf dot indicators */
.shelf-dots {
  display: flex;
  gap: 3px;
  padding: 4px 12px 0;
  align-items: center;
  flex-wrap: nowrap;
}

/* Wrapper sized to match its spine so the dot centers underneath */
.shelf-dot-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  cursor: pointer;
}

.shelf-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #2a2a2a;
  transition: background 0.15s, box-shadow 0.15s;
}

.shelf-dot-active {
  background: var(--pixel-green);
}

/* Shelf plank */
.shelf-plank {
  width: 100%;
}

.shelf-plank-top {
  height: 4px;
  background: #5c3a10;
  border-top: 2px solid #8b5a1a;
}

.shelf-plank-body {
  height: 10px;
  background: #3d2509;
  border-bottom: 2px solid #1a0e00;
}

/* Shelf supports */
.shelf-supports {
  display: flex;
  justify-content: space-between;
  padding: 0 24px;
}

.shelf-support {
  width: 12px;
  height: 20px;
  background: #3d2509;
  border-left: 2px solid #5c3a10;
  border-right: 2px solid #1a0e00;
}

/* ── Detail strip ── */
.lib-detail-strip {
  min-height: 96px;
  padding: 14px 16px;
  border-color: #333;
  animation: screenIn 0.15s ease-out;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.lib-detail-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68px;
  font-size: 6px;
  color: #444;
  letter-spacing: 2px;
}

.lib-detail-content {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}

.lib-detail-accent {
  width: 3px;
  align-self: stretch;
  min-height: 60px;
  border-radius: 1px;
  flex-shrink: 0;
}

.lib-detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 0;
}

.lib-detail-title {
  font-size: 8px;
  line-height: 1.6;
  font-family: var(--font-pixel);
}

.lib-detail-author {
  font-size: 6px;
  color: var(--pixel-gray);
  letter-spacing: 1px;
}

.lib-detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}

.lib-tag {
  font-size: 5px;
  padding: 2px 5px;
  border: 1px solid;
  font-family: var(--font-pixel);
  letter-spacing: 1px;
  text-transform: lowercase;
}

.lib-detail-desc {
  font-size: 6px;
  color: #888;
  line-height: 2;
  max-width: 480px;
}

.lib-detail-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
  flex-shrink: 0;
}

.lib-detail-meta-date {
  font-size: 6px;
  color: var(--pixel-gray);
  letter-spacing: 1px;
}

.lib-detail-read-badge {
  font-size: 6px;
  color: var(--pixel-green);
  letter-spacing: 1px;
}

.lib-open-btn {
  display: inline-block;
  font-size: 7px;
  font-family: var(--font-pixel);
  padding: 7px 14px;
  border: 2px solid;
  letter-spacing: 2px;
  transition: background 0.1s, color 0.1s;
  text-decoration: none;
  margin-top: auto;
}

.lib-open-btn:hover {
  background: currentColor;
  color: #000 !important;
}

/* ── Stats grid ── */
.lib-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.lib-stats-card {
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lib-card-title {
  font-size: 7px;
  color: #ffffff;
  letter-spacing: 2px;
}

.lib-card-divider {
  height: 1px;
  background: #222;
  margin: 0 -2px;
}

/* ── Big stats row ── */
.lib-big-stats {
  display: flex;
  gap: 20px;
  align-items: flex-end;
}

.lib-big-stat {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.lib-big-number {
  font-size: 24px;
  font-family: var(--font-pixel);
  line-height: 1;
}

.lib-big-label {
  font-size: 5px;
  color: #ffffff;
  letter-spacing: 1px;
}

/* ── Progress bars ── */
.lib-progress-rows {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.lib-progress-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.lib-progress-label {
  font-size: 5px;
  color: #ffffff;
  width: 64px;
  flex-shrink: 0;
  letter-spacing: 1px;
}

.lib-progress-track {
  flex: 1;
  height: 6px;
  background: #1a1a1a;
  border: 1px solid #222;
  position: relative;
  overflow: hidden;
}

.lib-progress-fill {
  height: 100%;
  transition: width 0.6s ease-out;
}

.lib-progress-count {
  font-size: 5px;
  color: var(--pixel-gray);
  width: 28px;
  text-align: right;
  flex-shrink: 0;
}

/* ── Monthly streak ── */
.lib-streak-section {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.lib-streak-label {
  font-size: 5px;
  color: #ffffff;
  letter-spacing: 2px;
}

.lib-streak-grid {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}

.lib-streak-block {
  width: 14px;
  height: 14px;
  background: #1a1a1a;
  border: 1px solid #252525;
  opacity: 0;
  transform: scale(0.6);
  transition: none;
}

.lib-streak-block.lib-streak-in {
  animation: streakPop 0.3s ease-out forwards;
}

.lib-streak-block.lib-streak-active {
  background: #003322;
  border-color: #00cc66;
}

.lib-streak-block.lib-streak-active.lib-streak-in {
  animation: streakPopActive 0.3s ease-out forwards;
}

@keyframes streakPop {
  0%   { opacity: 0; transform: scale(0.4); }
  60%  { opacity: 1; transform: scale(1.1); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes streakPopActive {
  0%   { opacity: 0; transform: scale(0.4); background: #003322; }
  60%  { opacity: 1; transform: scale(1.15); background: #00cc66; }
  100% { opacity: 1; transform: scale(1); background: #003322; }
}

/* ── Genre breakdown ── */
.lib-genre-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lib-genre-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.lib-genre-dot {
  width: 10px;
  height: 10px;
  flex-shrink: 0;
}

.lib-genre-name {
  font-size: 6px;
  width: 72px;
  flex-shrink: 0;
  letter-spacing: 1px;
}

.lib-genre-track {
  flex: 1;
  height: 6px;
  background: #111;
  border: 1px solid #1e1e1e;
  overflow: hidden;
}

.lib-genre-fill {
  height: 100%;
}

.lib-genre-count {
  font-size: 6px;
  width: 16px;
  text-align: right;
  flex-shrink: 0;
}

/* ── Recently added ── */
.lib-recent-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lib-recent-row {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  transition: opacity 0.1s;
}

.lib-recent-row:hover {
  opacity: 0.75;
}

.lib-recent-dot {
  width: 10px;
  height: 10px;
  flex-shrink: 0;
}

.lib-recent-title {
  font-size: 6px;
  flex: 1;
  color: #ccc;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.lib-recent-date {
  font-size: 5px;
  color: var(--pixel-gray);
  flex-shrink: 0;
  letter-spacing: 1px;
}

/* ── Right column ── */
.lib-right-col {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ─── CONTACT TERMINAL ───────────────────────────────────────── */
.contact {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.terminal {
  padding: 16px;
  background: #000;
  line-height: 2.2;
}

.t-line {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0;
}

.t-blank { height: 10px; }

.prompt { color: var(--pixel-green); font-size: 7px; }
.t-cmd  { color: var(--pixel-white); font-size: 7px; }
.t-val  { font-size: 7px; color: var(--pixel-white); padding-left: 16px; }
.t-key  { font-size: 7px; color: var(--pixel-gray); padding-left: 16px; min-width: 100px; display: inline-block; }
.t-link { font-size: 7px; color: var(--pixel-cyan); }
.t-link:hover { color: var(--pixel-amber); }

.t-val-inline { font-size: 7px; color: var(--pixel-white); padding-left: 16px; }
.t-error      { font-size: 7px; color: var(--pixel-red);   padding-left: 16px; }

.terminal-output {
  max-height: 55vh;
  overflow-y: auto;
  margin-bottom: 8px;
}

.t-input-row {
  display: flex;
  align-items: center;
  border-top: 1px solid var(--pixel-green);
  padding-top: 8px;
}

.t-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-family: var(--font-pixel);
  font-size: 7px;
  color: var(--pixel-white);
  caret-color: var(--pixel-green);
  line-height: 2;
}

/* ─── DIALOG LINKS ───────────────────────────────────────────── */
.dialog-links {
  display: flex;
  gap: 10px;
  margin-top: 10px;
  padding-top: 8px;
  border-top: 1px solid var(--pixel-green);
}

.dialog-link {
  font-size: 7px;
  color: var(--pixel-green);
  transition: color 0.1s;
}

.dialog-link:hover { color: var(--pixel-amber); }

/* ─── CURSOR ─────────────────────────────────────────────────── */
.cursor {
  display: inline-block;
  width: 7px;
  height: 12px;
  background: var(--pixel-green);
  animation: blink 1s step-end infinite;
  vertical-align: middle;
}

/* ─── KEYFRAME ANIMATIONS ────────────────────────────────────── */
@keyframes screenIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes glow {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.75; }
}

@keyframes hpPulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.6; }
}

@keyframes badgePulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

@keyframes bounce {
  from { transform: translateY(0); }
  to   { transform: translateY(-4px); }
}

@keyframes questWalk {
  from { transform: translateY(0px) rotate(-4deg); }
  to   { transform: translateY(-3px) rotate(4deg); }
}

/* ─── DUNGEON CRAWLER ────────────────────────────────────────── */
@keyframes roomPulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}

.dg-wrap {
  border: 2px solid var(--pixel-green);
  background: #060c06;
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

.dg-header {
  background: #000;
  border-bottom: 2px solid var(--pixel-green);
  padding: 6px 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.dg-title        { font-size: 8px; color: var(--pixel-amber); letter-spacing: 2px; }
.dg-floor-badge  { font-size: 6px; padding: 3px 8px; border: 1px solid var(--pixel-green); color: var(--pixel-green); }

.dg-body {
  display: grid;
  grid-template-columns: 210px 1fr;
  grid-template-rows: 1fr;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

/* ── Map Panel ── */
.dg-map-panel {
  background: #000;
  border-right: 2px solid #334433;
  padding: 10px 8px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  overflow: hidden;
}

.dg-map-label { font-size: 7px; color: #334433; letter-spacing: 1px; margin-bottom: 6px; }

.dg-map-canvas {
  position: relative;
  width: 190px;
  height: 160px;
  background: #080c08;
  border: 2px solid #334433;
  overflow: hidden;
  flex-shrink: 0;
}

.dg-room-node {
  position: absolute;
  width: 36px; height: 28px;
  border: 2px solid;
  display: flex; align-items: center; justify-content: center;
  font-size: 5px;
  cursor: pointer;
  user-select: none;
  transition: filter 0.1s;
}

.dg-room-node:hover            { filter: brightness(1.4); }
.dg-room-node--current         { animation: roomPulse 0.8s step-end infinite; }
.dg-room-node--locked          { opacity: 0.35; cursor: not-allowed; }

.dg-corridor-h { position: absolute; height: 2px; background: #334433; }
.dg-corridor-v { position: absolute; width:  2px; background: #334433; }

/* ── Legend ── */
.dg-legend { flex-shrink: 0; }
.dg-legend-row {
  display: flex; align-items: center; gap: 7px;
  font-size: 7px; color: #334433; margin-bottom: 6px;
}
.dg-legend-box { width: 14px; height: 14px; border: 1px solid; flex-shrink: 0; }

/* ── Floor list ── */
.dg-floor-list-wrap { margin-top: auto; }
.dg-floor-list { display: flex; flex-direction: column; gap: 4px; }

.dg-floor-list-label {
  font-size: 6px;
  color: var(--pixel-amber);
  letter-spacing: 1px;
  margin-bottom: 5px;
  animation: badgePulse 2s ease-in-out infinite;
}

.dg-floor-hint {
  font-size: 5px;
  color: #556655;
  margin-top: 4px;
  letter-spacing: 1px;
}

.dg-floor-btn {
  font-family: var(--font-pixel);
  font-size: 6px; padding: 6px 6px;
  background: transparent;
  border: 1px solid #556655;
  color: #aabbaa;
  cursor: pointer; text-align: left;
  transition: all 0.1s;
  display: flex; align-items: center; gap: 4px;
}
.dg-floor-btn:hover {
  border-color: var(--pixel-amber);
  color: var(--pixel-amber);
  background: rgba(255, 183, 0, 0.06);
}
.dg-floor-btn--active {
  border-color: var(--pixel-green) !important;
  color: var(--pixel-green) !important;
  background: rgba(0, 204, 102, 0.1) !important;
}

.dg-floor-btn-arrow { font-size: 6px; flex-shrink: 0; }

/* ── Main Panel ── */
.dg-main-panel {
  background: #0a0f0a;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

.dg-room-header {
  border-bottom: 2px solid #334433;
  padding: 8px 14px;
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
}

.dg-room-id   { font-size: 6px; color: #334433; }
.dg-type-badge { font-size: 5px; padding: 2px 7px; border: 1px solid; }

.dg-room-content {
  flex: 1;
  min-height: 0;
  padding: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ── Nav Bar ── */
.dg-nav-bar {
  border-top: 2px solid #334433;
  padding: 7px 14px;
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
  background: rgba(0,0,0,0.3);
}

.dg-nav-keys  { display: flex; align-items: center; gap: 5px; }
.dg-nav-hint  { font-size: 5px; color: #334433; margin-left: 4px; }
.dg-nav-status { font-size: 5px; color: #334433; }

.dg-nav-btn {
  font-family: var(--font-pixel);
  font-size: 5px; padding: 3px 6px;
  background: #1a2a1a;
  border: 2px solid #334433;
  color: #334433;
  cursor: pointer;
  min-width: 24px; text-align: center;
  transition: all 0.08s;
}
.dg-nav-btn:hover:not(:disabled) { border-color: var(--pixel-green); color: var(--pixel-green); }
.dg-nav-btn:disabled { opacity: 0.25; cursor: not-allowed; }

/* ── Entry Room ── */
.dg-entry-room { padding: 16px; }

/* Hero sprite row */
.dg-hero-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
  margin-bottom: 18px;
  flex-wrap: nowrap;
}

.dg-hero-sprite {
  flex-shrink: 0;
  filter: drop-shadow(0 0 4px #00cc66);
  animation: bounce 0.8s ease-in-out infinite alternate;
  margin-right: 4px;
}

/* Thought bubble — matches quest log style */
.dg-thought-bubble {
  position: relative;
  background: #fff;
  border: 1px solid #fff;
  border-radius: 6px;
  padding: 6px 10px;
  font-size: 5px;
  color: #000;
  line-height: 2.2;
  margin-left: 18px;
  margin-top: -12px;
  white-space: nowrap;
  animation: screenIn 0.15s ease-out;
}

/* Two dots to the left of the bubble */
.dg-thought-bubble::before {
  content: '· ·';
  position: absolute;
  right: calc(100% + 2px);
  bottom: 4px;
  font-size: 7px;
  color: #fff;
  letter-spacing: 2px;
  line-height: 1;
}

/* Smallest dot, drops below */
.dg-thought-bubble::after {
  content: '·';
  position: absolute;
  right: calc(100% - 2px);
  bottom: -7px;
  font-size: 10px;
  color: #fff;
  line-height: 1;
}

.dg-thought-dim { color: #555; font-size: 5px; }

.dg-stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
.dg-stat-box  { border: 1px solid #334433; padding: 8px; text-align: center; }
.dg-stat-num  { font-size: 14px; color: var(--pixel-green); margin-bottom: 4px; }
.dg-stat-lab  { font-size: 5px; color: #334433; }

/* ── Boss Card ── */
.dg-boss-card { border: 2px solid; padding: 12px; margin-bottom: 10px; }
.dg-boss-name { font-size: 9px; margin-bottom: 8px; }
.dg-boss-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.dg-boss-type { font-size: 6px; color: #334433; }
.dg-diff-badge { font-size: 5px; padding: 2px 6px; border: 1px solid; }

.dg-boss-actions { display: flex; align-items: center; gap: 10px; margin-top: 8px; flex-wrap: wrap; }

/* ── HP Bar ── */
.dg-hp-row   { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.dg-hp-label { font-size: 6px; min-width: 18px; }
.dg-hp-track { flex: 1; height: 8px; background: #1a0000; border: 1px solid #330000; overflow: hidden; }
.dg-hp-fill  { height: 100%; transition: width 0.6s ease; }
.dg-hp-val   { font-size: 5px; min-width: 45px; text-align: right; }

/* ── Shared atoms ── */
.dg-desc { font-size: 7px; color: var(--pixel-white); line-height: 2; margin-bottom: 8px; }
.dg-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 10px; }
.dg-tag  { font-size: 5px; padding: 2px 6px; border: 1px solid; }
.dg-link { font-size: 6px; transition: filter 0.1s; }
.dg-link:hover { filter: brightness(1.4); }

/* ── Raid button ── */
.dg-raid-btn {
  font-family: var(--font-pixel);
  font-size: 7px; padding: 7px 14px;
  background: transparent; cursor: pointer;
  border: 2px solid;
  transition: background 0.1s;
}
.dg-raid-btn:hover { background: rgba(255,255,255,0.06); }

/* ── Battle Screen ── */
.dg-battle-screen { padding: 12px; }

.dg-back-btn {
  font-family: var(--font-pixel);
  font-size: 6px; padding: 5px 10px;
  background: transparent;
  border: 2px solid #334433; color: #334433;
  cursor: pointer; margin-bottom: 12px;
  display: block; transition: all 0.1s;
}
.dg-back-btn:hover { border-color: var(--pixel-green); color: var(--pixel-green); }

.dg-battle-title  { font-size: 7px; text-align: center; margin-bottom: 14px; }
.dg-battle-phases { display: flex; flex-direction: column; gap: 8px; }

.dg-phase          { border: 1px solid #334433; padding: 9px; }
.dg-phase--active  { border-color: #ff3333; background: rgba(255,51,51,0.04); }

.dg-phase-label             { font-size: 6px; color: #334433; margin-bottom: 5px; }
.dg-phase--active .dg-phase-label { color: #ff3333; }
.dg-phase-text  { font-size: 6px; color: var(--pixel-white); line-height: 1.9; }

.dg-ability-row { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 7px; }
.dg-ability     { font-size: 5px; padding: 2px 7px; border: 1px solid var(--pixel-purple); color: var(--pixel-purple); }

/* ── Vault Room ── */
.dg-vault-room   { padding: 4px; flex: 1; min-height: 0; overflow-y: auto; }
.dg-vault-header { font-size: 7px; color: var(--pixel-amber); margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #334433; }

.dg-vault-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.dg-vault-card {
  border: 2px solid; background: #050c05;
  padding: 8px;
  display: flex; gap: 8px; align-items: flex-start;
  transition: filter 0.1s;
}
.dg-vault-card:hover { filter: brightness(1.15); }

.dg-vault-icon  { font-size: 18px; flex-shrink: 0; animation: vaultPulse 2s ease-in-out infinite; }
.dg-vault-info  { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.dg-vault-name  { font-size: 7px; word-break: break-all; }
.dg-vault-meta  { font-size: 5px; color: #334433; }
.dg-vault-desc  { font-size: 5px; color: var(--pixel-white); line-height: 1.8; }
.dg-vault-links { display: flex; align-items: center; gap: 8px; margin-top: 2px; }

/* ── Chronicle Room ── */
.dg-chronicle-room { padding: 8px 4px; display: flex; flex-direction: column; gap: 10px; width: 100%; box-sizing: border-box; position: relative; flex: 1; min-height: 0; overflow: hidden; }

.dg-cal-tooltip {
  position: absolute;
  transform: translateX(-50%);
  background: #0a0a0a;
  border: 1px solid #444;
  color: #ffffff;
  font-size: 6px;
  padding: 3px 6px;
  white-space: nowrap;
  pointer-events: none;
  z-index: 10;
  letter-spacing: 0.05em;
}

.dg-cal-wrap {
  display: flex;
  gap: 6px;
  width: 100%;
  overflow-x: auto;
}

.dg-cal-days {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  height: calc(88px + 16px + 3px); /* grid + spacer + months margin */
}
.dg-cal-day-spacer { height: 16px; flex-shrink: 0; margin-bottom: 3px; }
.dg-cal-day-label { font-size: 5px; color: #888888; flex: 1; display: flex; align-items: center; letter-spacing: 0.03em; padding-right: 4px; }

.dg-cal-months {
  display: flex;
  gap: 3px;
  height: 16px;
  align-items: flex-end;
  margin-bottom: 3px;
}
.dg-cal-month-cell {
  flex: 1;
  font-size: 5px;
  color: #888888;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  letter-spacing: 0.03em;
}

.dg-cal-grid {
  display: flex;
  gap: 3px;
  flex: 1;
  min-width: 0;
  height: 88px;
}

.dg-cal-week {
  display: flex;
  flex-direction: column;
  gap: 3px;
  flex: 1;
  min-width: 0;
}

.dg-cal-cell {
  width: 100%;
  flex: 1;
  border: 1px solid;
  border-radius: 2px;
  flex-shrink: 0;
  transition: filter 0.12s, transform 0.1s;
  min-width: 4px;
}
.dg-cal-cell:hover { filter: brightness(2) saturate(1.4); transform: scale(1.3); cursor: default; z-index: 1; position: relative; }

.dg-cal-legend {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-top: 2px;
}
.dg-cal-legend-label { font-size: 5px; color: #4a7a4a; letter-spacing: 0.05em; }
.dg-cal-legend .dg-cal-cell { width: 11px; height: 11px; aspect-ratio: unset; flex-shrink: 0; }

/* ── Activity Log ── */
.dg-chronicle-bottom {
  display: flex;
  gap: 10px;
  align-items: stretch;
  border-top: 1px solid #1a2a1a;
  padding-top: 10px;
  margin-top: 2px;
  flex: 1;
  min-height: 0;
}

.dg-activity-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

/* scroll anchor: fills remaining space, log scrolls inside it */
.dg-activity-scroll-anchor {
  flex: 1;
  min-height: 0;
  position: relative;
}

.dg-activity-log {
  position: absolute;
  inset: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding-bottom: 8px;
}

.dg-activity-header {
  font-size: 7px;
  color: #ffffff;
  margin-bottom: 4px;
  letter-spacing: 0.08em;
}

.dg-activity-row {
  display: flex;
  gap: 8px;
  align-items: baseline;
  font-size: 6px;
  line-height: 1.6;
}

.dg-activity-date   { color: #334433; flex-shrink: 0; }
.dg-activity-prefix { flex-shrink: 0; font-weight: bold; }
.dg-activity-text   { color: #aaaaaa; }

/* ── Loading / Error ── */
.dg-loading { display: flex; align-items: center; gap: 8px; padding: 16px; font-size: 7px; color: #334433; }
.dg-error   { padding: 10px; font-size: 7px; color: var(--pixel-amber); }


/* ── Char Stats Panel ── */
.dg-char-stats-panel {
  width: 140px;
  flex-shrink: 0;
  background: #050c05;
  border: 1px solid #1a3a1a;
  padding: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dg-char-stats-header {
  font-size: 6px;
  color: var(--pixel-green);
  letter-spacing: 2px;
  border-bottom: 1px solid #1a3a1a;
  padding-bottom: 5px;
  margin-bottom: 7px;
  width: 100%;
  text-align: center;
}

.dg-char-sprite-wrap {
  margin-bottom: 5px;
  opacity: 0.9;
}

.dg-char-id-name {
  font-size: 5px;
  color: var(--pixel-white);
  letter-spacing: 1px;
  margin-bottom: 2px;
  text-align: center;
}

.dg-char-id-class {
  font-size: 4px;
  color: var(--pixel-amber);
  letter-spacing: 1px;
  margin-bottom: 5px;
  text-align: center;
}

.dg-char-id-level {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 7px;
}

.dg-char-lv-badge {
  font-size: 5px;
  color: #334433;
  background: #0a140a;
  padding: 1px 3px;
  border: 1px solid #1a3a1a;
}

.dg-char-lv-num {
  font-size: 11px;
  color: var(--pixel-green);
  line-height: 1;
}

.dg-char-divider {
  width: 100%;
  height: 1px;
  background: #1a3a1a;
  margin: 4px 0 7px;
}

.dg-char-stat-block {
  width: 100%;
  margin-bottom: 7px;
}

.dg-char-stat-head {
  display: flex;
  align-items: baseline;
  gap: 3px;
  margin-bottom: 3px;
}

.dg-char-stat-name {
  font-size: 7px;
  font-weight: bold;
  flex-shrink: 0;
}

.dg-char-stat-sub {
  font-size: 4px;
  color: #334433;
  flex: 1;
  letter-spacing: 0.5px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dg-char-stat-val {
  font-size: 6px;
  flex-shrink: 0;
}

.dg-char-seg-track {
  display: flex;
  gap: 1px;
  width: 100%;
}

.dg-char-seg {
  flex: 1;
  height: 6px;
  border: 1px solid #1a3a1a;
  transition: background 0.5s ease, box-shadow 0.5s ease;
}

.dg-char-stat-hint {
  font-size: 4px;
  color: #1a3a1a;
  text-align: center;
  letter-spacing: 0.5px;
  line-height: 1.6;
  margin-top: 4px;
}

/* ── Mobile ── */
@media (max-width: 640px) {
  .dg-body                         { grid-template-columns: 1fr; }
  .dg-map-panel                    { display: none; }
  .dg-chronicle-bottom             { flex-direction: column; }
  .dg-vault-grid                   { grid-template-columns: 1fr; }
}

/* ─── SCROLLBAR ──────────────────────────────────────────────── */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--pixel-darker); }
::-webkit-scrollbar-thumb { background: #555555; }

/* ─── MOBILE ─────────────────────────────────────────────────── */
@media (max-width: 640px) {
  html, body, #root { font-size: 9px; }
  .game-shell { border-width: 0; }
  .inv-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-grid { grid-template-columns: 1fr; }
  .nav-btn { font-size: 5px; padding: 8px 2px; }
  .top-bar-title { font-size: 7px; }
  .home-top { flex-direction: column; }
  .edu-grid { grid-template-columns: 1fr; }
  .lib-stats-grid { grid-template-columns: 1fr; }
  .lib-big-number { font-size: 18px; }
}
